# Required
BOT_TOKEN=
APPLICATION_ID=
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Optional
INVITATION_URL=
LOG_LEVEL=INFO
# 本番環境では必ず production を設定（未設定時は pino-pretty による整形ログを使用）
NODE_ENV=production
# Sentry DSN（TODO: Sentry SDK初期化は未実装。将来的に追加予定）
SENTRY_DSN=
# サポートサーバーの招待URL（/help コマンドで表示）
SUPPORT_SERVER_URL=https://discord.gg/MyaZRuze23
# 開発用: 指定するとグローバルではなくギルドコマンドとして登録（レート制限回避）
DEV_GUILD_ID=
